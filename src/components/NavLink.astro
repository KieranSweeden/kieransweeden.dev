---
export interface Props {
  label: string;
  path: string;
}

const { label, path } = Astro.props;

const isActive = Astro.url.pathname === path;

const colourRendered = isActive
  ? "text-zinc-500 dark:text-zinc-200"
  : "text-zinc-500 dark:text-zinc-500";
---

<a
  href={path}
  class=`block ${colourRendered} hover:text-zinc-50 hover:underline`>{label}</a
>
